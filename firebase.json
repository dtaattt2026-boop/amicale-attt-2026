{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".github/**",
      ".venv/**",
      "**/*.md",
      "**/node_modules/**",
      "**/.git/**"
    ],
    "rewrites": [],
    "headers": [
      {
        "source": "**/*.@(js|css)",
        "headers": [
          { "key": "Cache-Control", "value": "max-age=86400" }
        ]
      }
    ],
    "cleanUrls": false,
    "trailingSlash": false
  }
}
